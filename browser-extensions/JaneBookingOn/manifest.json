{
  "manifest_version": 3,
  "name": "JaneBookingOn",
  "version": "1.0.0",
  "description": "Enable Online Booking, set Rolling Availability to No Limit, save, and continue to the next staff edit page.",
  "permissions": ["tabs", "scripting"],
  "host_permissions": ["https://vcmt.janeapp.com/*"],
  "action": {
    "default_title": "Run JaneBookingOn"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://vcmt.janeapp.com/admin*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
