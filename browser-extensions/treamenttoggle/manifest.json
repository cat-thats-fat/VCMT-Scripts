{
  "manifest_version": 3,
  "name": "Treament Toggle",
  "version": "1.0.0",
  "description": "Apply treatment mode presets (intermediate, advanced, hybrid) for staff members and navigate through staff IDs automatically.",
  "permissions": ["tabs", "scripting"],
  "host_permissions": ["https://vcmt.janeapp.com/*"],
  "action": {
    "default_title": "Run Treament Toggle"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://vcmt.janeapp.com/admin*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
