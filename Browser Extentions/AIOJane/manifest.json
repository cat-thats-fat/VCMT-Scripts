{
  "manifest_version": 3,
  "name": "JaneApp Online Booking Helper",
  "version": "1.0.0",
  "description": "Open staff edit page, set Online Booking max bookable offset to 1 month, save, and move to the next staff ID.",
  "permissions": ["tabs", "scripting"],
  "host_permissions": [
    "https://vcmt.janeapp.com/*"
  ],
  "action": {
    "default_title": "Run JaneApp Online Booking Helper"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://vcmt.janeapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
